# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit real keys.
GEOAPIFY_KEY=
IMGBB_KEY=
GEMINI_KEY=
# Public base URL of the deployed push relay (Vercel). NO trailing /api/send —
# the app appends it. e.g. https://lifeline-push-relay.vercel.app
PUSH_RELAY_URL=
# Agora RTC App ID (voice/video calls) — from the Agora console project.
AGORA_APP_ID=
