rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Chat voice notes. chatId is `sorted(uidA, uidB).join('_')`, so
    // membership is provable from the path itself (same trick as the
    // Firestore /chats rules). Reads happen via the tokenized download URL,
    // but keep them participant-scoped for direct SDK access too.
    match /chat_media/{chatId}/{fileName} {
      allow read, write: if request.auth != null
        && request.auth.uid in chatId.split('_');
    }
  }
}
