rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // ---- users ----
    // Readable by any signed-in user: donation discovers donors across users,
    // and chat resolves a peer uid by phone lookup. Writable only by owner.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == uid;

      // contacts: private to owner
      match /contacts/{contactId} {
        allow read, write: if isSignedIn() && request.auth.uid == uid;
      }

      // donation_posts: any signed-in user can read; only the owner creates/
      // deletes. A donor may accept an open post by writing ONLY the accept
      // fields, setting acceptedBy to themselves, once.
      match /donation_posts/{postId} {
        allow read: if isSignedIn();
        allow create, delete: if isSignedIn() && request.auth.uid == uid;
        allow update: if isSignedIn() && (
          request.auth.uid == uid ||
          (
            request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['acceptedBy', 'acceptedByName', 'acceptedAt', 'status'])
            && request.resource.data.acceptedBy == request.auth.uid
            && request.resource.data.status == 'accepted'
            && !(resource.data.keys().hasAny(['acceptedBy'])
                 && resource.data.acceptedBy != null
                 && resource.data.acceptedBy != '')
          )
        );
      }
    }

    // ---- chats ----
    // chatId is `sorted(uidA, uidB).join('_')`, so membership is provable from
    // the id itself — no get() on the (possibly not-yet-created) parent doc.
    match /chats/{chatId} {
      function isParticipant() {
        return isSignedIn() && request.auth.uid in chatId.split('_');
      }

      allow read: if isParticipant();
      // create/update must keep the caller in the participants array
      allow write: if isParticipant()
        && request.auth.uid in request.resource.data.participants;

      match /messages/{messageId} {
        allow read: if isParticipant();
        allow create: if isParticipant()
          && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if isParticipant();
      }
    }

    // ---- live_locations ----
    // Session ids are unguessable random doc ids handed to recipients via an
    // emergency chat message. Any signed-in user may read (they need the id);
    // only the owner may create/update/delete the session.
    match /live_locations/{sessionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isSignedIn()
        && resource.data.ownerUid == request.auth.uid;
    }
  }
}
